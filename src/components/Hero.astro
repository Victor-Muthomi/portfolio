---
interface Props {
  name?: string;
  title?: string;
  subtitle?: string;
  description?: string;
}

const {
  name = 'Victor Muthomi',
  title = 'Software Engineer | Full-Stack Developer',
  subtitle = 'Building scalable solutions across ERP systems, mobile applications, and AI/ML integration',
  description = 'Accomplished software engineer with expertise in full-stack development using Python, FastAPI, Flask, Flutter, and ERP/Frappe frameworks. Passionate about advancing the intersection of software engineering, automation, and intelligent systems.'
} = Astro.props;
---

<section class="hero" id="hero">
  <div class="container hero-content">
    <!-- Main Content -->
    <div class="hero-text">
      <!-- Greeting -->
      <div class="hero-intro">
        <span class="wave-emoji">👋</span>
        <span class="intro-label">Hello, I'm</span>
      </div>

      <!-- Name -->
      <h1 class="hero-name">
        {name}
      </h1>

      <!-- Title with Gradient -->
      <h2 class="hero-title">
        <span class="gradient-text-accent">{title}</span>
      </h2>

      <!-- Subtitle -->
      <p class="hero-subtitle">
        {subtitle}
      </p>

      <!-- Description -->
      <p class="hero-description">
        {description}
      </p>

      <!-- Quick Stats -->
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-emoji">💼</span>
          <span class="stat-text">20+ Projects</span>
        </div>
        <div class="stat-divider">•</div>
        <div class="stat-item">
          <span class="stat-emoji">⚡</span>
          <span class="stat-text">100+ Technologies</span>
        </div>
        <div class="stat-divider">•</div>
        <div class="stat-item">
          <span class="stat-emoji">🎯</span>
          <span class="stat-text">4+ Years Experience</span>
        </div>
      </div>
    </div>

    <!-- Decorative Element -->
    <div class="hero-decoration" aria-hidden="true">
      <div class="decoration-circle circle-1" data-parallax="0.3"></div>
      <div class="decoration-circle circle-2" data-parallax="0.5"></div>
      <div class="decoration-circle circle-3" data-parallax="0.2"></div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--space-4xl) + 80px) 0 var(--space-4xl);
    overflow: hidden;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: var(--space-3xl);
    position: relative;
    z-index: 1;
  }

  /* Text Content */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 900px;
  }

  .hero-intro {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.2s forwards;
  }

  .wave-emoji {
    font-size: 2rem;
    animation: wave 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
  }

  @keyframes wave {
    0%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60%, 100% { transform: rotate(0deg); }
  }

  .intro-label {
    font-size: 1.125rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
  }

  .hero-name {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: var(--font-weight-black);
    line-height: 1.1;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
  }

  .hero-title {
    font-size: clamp(1.5rem, 5vw, 3rem);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    margin: 0;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.4s forwards;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.5s forwards;
  }

  .hero-description {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.7;
    color: var(--color-text-tertiary);
    max-width: 700px;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.6s forwards;
  }

  /* Quick Stats */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.8s forwards;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .stat-emoji {
    font-size: 1.25rem;
  }

  .stat-text {
    font-size: 0.9375rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
  }

  .stat-divider {
    color: var(--color-text-muted);
  }

  /* Decorative Elements */
  .hero-decoration {
    position: absolute;
    top: 50%;
    right: 10%;
    width: 500px;
    height: 500px;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 0;
  }

  .decoration-circle {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    opacity: 0.3;
  }

  .circle-1 {
    width: 300px;
    height: 300px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
    animation: pulse 8s ease-in-out infinite;
  }

  .circle-2 {
    width: 400px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, transparent 70%);
    animation: pulse 8s ease-in-out 1s infinite;
  }

  .circle-3 {
    width: 500px;
    height: 500px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(139, 92, 246, 0.06) 0%, transparent 70%);
    animation: pulse 8s ease-in-out 2s infinite;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.3;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.05);
      opacity: 0.2;
    }
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 60px);
      padding: calc(var(--space-3xl) + 60px) 0 var(--space-3xl);
    }

    .hero-text {
      gap: var(--space-md);
    }

    .hero-stats {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .stat-divider {
      display: none;
    }

    .hero-decoration {
      right: -25%;
      width: 400px;
      height: 400px;
      opacity: 0.5;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .hero-decoration {
      right: 0;
      width: 450px;
      height: 450px;
      opacity: 0.7;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-name,
    .hero-title,
    .hero-subtitle,
    .hero-description,
    .hero-intro,
    .hero-stats {
      animation: none;
      opacity: 1;
    }

    .wave-emoji,
    .decoration-circle {
      animation: none;
    }
  }
</style>
