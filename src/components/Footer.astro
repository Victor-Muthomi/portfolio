---
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/Victor-Muthomi',
    type: 'svg',
    username: '@Victor-Muthomi'
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/victor-muthomi-497b173a4/',
    type: 'svg',
    username: 'Victor Muthomi'
  },
  {
    label: 'Email',
    href: 'mailto:muthomivictor367@gmail.com',
    type: 'emoji',
    emoji: '📧',
    username: 'mail@victorblog.me'
  },
  {
    label: 'WhatsApp',
    href: 'https://wa.me/254712550618',
    type: 'svg',
    username: '+254 712 550 618'
  }
];

const quickLinks = [
  { label: 'Home', href: '/', emoji: '🏠', download: false },
  { label: 'Projects', href: '/projects', emoji: '🚀', download: false },
  { label: 'Skills', href: '/skills', emoji: '⚒️', download: false },
  // { label: 'Downloads', href: '/downloads', emoji: '📥', download: false },
  // { label: 'Resume', href: '/files/resume.pdf', emoji: '📄', download: true }
];
---

<footer class="modern-footer">
  <div class="footer-glow"></div>
  
  <div class="footer-container">
    <!-- Main Footer Content -->
    <div class="footer-grid">
      <!-- Brand Section -->
      <div class="footer-brand">
        <a href="/" class="brand-link">
          <span class="brand-emoji">👨‍💻</span>
          <span class="brand-name">Victor Muthomi</span>
        </a>
        <p class="brand-tagline">
          Software Engineer crafting elegant solutions for complex problems.
        </p>
        <div class="availability-badge">
          <span class="pulse-dot"></span>
          <span>Available for opportunities</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-section">
        <h4 class="section-title">
          <span>🔗</span> Quick Links
        </h4>
        <nav class="footer-nav">
          {quickLinks.map((link) => (
            <a href={link.href} class="footer-link" download={link.download || undefined}>
              <span class="link-emoji">{link.emoji}</span>
              <span>{link.label}</span>
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact Section -->
      <div class="footer-section">
        <h4 class="section-title">
          <span>📬</span> Get In Touch
        </h4>
        <div class="contact-links">
          {socialLinks.map((link) => (
            <a 
              href={link.href}
              class="contact-link"
              target={link.label !== 'Email' ? '_blank' : undefined}
              rel={link.label !== 'Email' ? 'noopener noreferrer' : undefined}
              aria-label={`Contact via ${link.label}`}
            >
              <span class="contact-emoji">
                {link.type === 'emoji' && link.emoji}
                {link.label === 'GitHub' && (
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                )}
                {link.label === 'LinkedIn' && (
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                )}
                {link.label === 'WhatsApp' && (
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                )}
              </span>
              <div class="contact-info">
                <span class="contact-label">{link.label}</span>
                <span class="contact-value">{link.username}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <div class="footer-divider"></div>
      <div class="footer-bottom-content">
        <p class="copyright">
          <span>✨</span> {currentYear} Victor Muthomi. Build with passion.
        </p>
        <div class="footer-badges">
          <span class="tech-badge">⚡ Fast</span>
          <span class="tech-badge">🎨 Modern</span>
          <span class="tech-badge">📱 Responsive</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .modern-footer {
    position: relative;
    background: linear-gradient(180deg, var(--color-bg-primary) 0%, var(--color-bg-secondary) 100%);
    border-top: 1px solid var(--color-border);
    padding: var(--space-4xl) 0 var(--space-xl);
    margin-top: auto;
    overflow: hidden;
  }

  .footer-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent-cyan), var(--color-accent-indigo), transparent);
    opacity: 0.5;
  }

  .footer-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }

  /* Brand Section */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    transition: transform var(--transition-fast);
  }

  .brand-link:hover {
    transform: translateX(4px);
  }

  .brand-emoji {
    font-size: 2rem;
  }

  .brand-name {
    font-size: 1.5rem;
    font-weight: var(--font-weight-bold);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-tagline {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 280px;
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    color: var(--color-accent-cyan);
    width: fit-content;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent-cyan);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  /* Footer Sections */
  .footer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1.125rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* Quick Links */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: all var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-accent-cyan);
    transform: translateX(4px);
  }

  .link-emoji {
    font-size: 1rem;
    transition: transform var(--transition-fast);
  }

  .footer-link:hover .link-emoji {
    transform: scale(1.2);
  }

  /* Contact Links */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--glass-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .contact-link:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: var(--color-accent-indigo);
    transform: translateY(-2px);
  }

  .contact-emoji {
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .contact-link:hover .contact-emoji {
    transform: scale(1.1);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: 0.875rem;
    color: var(--color-text-primary);
  }

  /* Footer Bottom */
  .footer-bottom {
    padding-top: var(--space-xl);
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin-bottom: var(--space-xl);
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .copyright {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    margin: 0;
  }

  .footer-badges {
    display: flex;
    gap: var(--space-sm);
  }

  .tech-badge {
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  /* Responsive */
  @media (max-width: 968px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .footer-brand {
      grid-column: 1 / -1;
      text-align: center;
      align-items: center;
    }

    .brand-tagline {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .modern-footer {
      padding: var(--space-3xl) 0 var(--space-lg);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
      text-align: center;
    }

    .footer-section {
      align-items: center;
    }

    .footer-nav {
      align-items: center;
    }

    .contact-links {
      width: 100%;
      max-width: 320px;
    }

    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-badges {
      justify-content: center;
    }
  }
</style>
