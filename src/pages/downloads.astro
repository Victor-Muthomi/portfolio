---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';

const downloads = [
  {
    title: 'Professional Resume',
    description: 'Comprehensive CV including experience, education, and technical skills',
    fileType: 'PDF',
    fileSize: '194 KB',
    fileName: 'resume.pdf',
    icon: '📄',
    primary: true
  },
  {
    title: 'Portfolio Case Studies',
    description: 'Detailed technical documentation of featured projects',
    fileType: 'PDF',
    fileSize: '1.2 MB',
    fileName: 'case-studies.pdf',
    icon: '📊',
    primary: false
  },
  {
    title: 'Technical Certifications',
    description: 'AWS, Azure, and other professional certifications',
    fileType: 'PDF',
    fileSize: '890 KB',
    fileName: 'certifications.pdf',
    icon: '🎓',
    primary: false
  },
  {
    title: 'Code Samples & Demos',
    description: 'Repository of code examples and project demonstrations',
    fileType: 'ZIP',
    fileSize: '4.5 MB',
    fileName: 'code-samples.zip',
    icon: '💻',
    primary: false
  }
];
---

<MainLayout
  title="Downloads | Victor Muthomi - Software Engineer"
  description="Download my resume, portfolio case studies, certifications, and code samples."
>
  <!-- Navigation -->
  <Navbar slot="nav" developerName="Victor Muthomi" currentPath="/downloads" />

  <!-- Downloads Header -->
  <section class="downloads-hero">
    <div class="container">
      <div class="hero-content">
        <h1>
          <span class="title-emoji">📥</span> <span class="gradient-text-accent">Downloads</span> & Resources
        </h1>
        <p class="hero-description">
          Access my resume, project documentation, certifications, and code samples. 
          Everything you need to get a comprehensive view of my work and expertise.
        </p>
        <div class="hero-stats" data-animate="stagger" data-stagger-delay="100">
          <div class="stat-item">
            <span class="stat-emoji">📦</span>
            <span class="stat-value gradient-text">4</span>
            <span class="stat-label">Resources</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-emoji">💾</span>
            <span class="stat-value gradient-text">6+</span>
            <span class="stat-label">MB Total</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-emoji">📋</span>
            <span class="stat-value gradient-text">PDF</span>
            <span class="stat-label">Formats</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Downloads Grid Section -->
  <section class="downloads-section">
    <div class="container">
      <div class="downloads-grid" data-animate="stagger" data-stagger-delay="150">
        {downloads.map((item) => (
          <div class={`download-card glass ${item.primary ? 'primary' : ''}`} data-tilt>
            <div class="card-header">
              <span class="file-icon">{item.icon}</span>
              <div class="file-meta">
                <span class="file-type">{item.fileType}</span>
                <span class="file-size">{item.fileSize}</span>
              </div>
            </div>
            
            <div class="card-content">
              <h3 class="download-title">{item.title}</h3>
              <p class="download-description">{item.description}</p>
            </div>

            <div class="card-footer">
              <a 
                href={`/files/${item.fileName}`} 
                download
                class={`btn-download ${item.primary ? 'btn-gradient' : 'btn-secondary'}`}
              >
                <span>⬇️</span>
                Download {item.fileType}
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="downloads-footer glass" data-animate="fade-up">
        <div class="footer-content">
          <span class="footer-emoji">🤔</span>
          <div class="footer-text">
            <h3>Looking for specific information?</h3>
            <p>Feel free to reach out if you need additional materials or have questions about my work.</p>
          </div>
          <div class="footer-actions">
            <a href="/projects" class="btn btn-outline">
              <span>🚀</span> View Projects
            </a>
            <a href="/skills" class="btn btn-outline">
              <span>⚡</span> See Skills
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Downloads Hero */
  .downloads-hero {
    padding: calc(var(--space-5xl) + 80px) 0 var(--space-4xl);
    background: 
      radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(6, 182, 212, 0.1) 0%, transparent 50%);
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: var(--font-weight-black);
    margin-bottom: var(--space-lg);
    line-height: 1.1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .title-emoji {
    font-size: 0.9em;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .hero-description {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-3xl);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .stat-emoji {
    font-size: 1.5rem;
    transition: transform var(--transition-normal);
  }

  .stat-item:hover .stat-emoji {
    transform: scale(1.2);
  }

  .stat-value {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-black);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: var(--font-weight-medium);
  }

  .stat-divider {
    width: 1px;
    height: 60px;
    background: var(--color-border);
  }

  /* Downloads Section */
  .downloads-section {
    padding: var(--space-4xl) var(--space-lg);
    background: var(--color-bg-primary);
    position: relative;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-3xl);
  }

  .download-card {
    padding: var(--space-xl);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    transition: all var(--transition-normal);
    animation: fadeInUp 0.6s ease-out backwards;
  }

  .download-card:nth-child(1) { animation-delay: 0.1s; }
  .download-card:nth-child(2) { animation-delay: 0.2s; }
  .download-card:nth-child(3) { animation-delay: 0.3s; }
  .download-card:nth-child(4) { animation-delay: 0.4s; }

  .download-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-indigo);
  }

  .download-card.primary {
    border: 2px solid var(--color-accent-indigo);
    background: linear-gradient(
      135deg,
      rgba(99, 102, 241, 0.05),
      rgba(6, 182, 212, 0.05)
    );
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .file-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .file-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .file-type {
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .file-size {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
  }

  .card-content {
    flex: 1;
    margin-bottom: var(--space-lg);
  }

  .download-title {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .download-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .card-footer {
    margin-top: auto;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-full);
    font-size: 0.9375rem;
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: all var(--transition-normal);
    cursor: pointer;
    border: none;
  }

  .btn-gradient {
    background: linear-gradient(135deg, var(--color-accent-indigo), var(--color-accent-cyan));
    color: white;
  }

  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
  }

  .btn-secondary {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
  }

  .btn-secondary:hover {
    background: var(--color-bg-tertiary);
    border-color: var(--color-accent-indigo);
  }

  .downloads-footer {
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    animation: fadeInUp 0.6s ease-out 0.5s backwards;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .footer-emoji {
    font-size: 3rem;
    flex-shrink: 0;
  }

  .footer-actions {
    display: flex;
    gap: var(--space-md);
    flex-shrink: 0;
  }

  .footer-text h3 {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-xs);
  }

  .footer-text p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-full);
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: all var(--transition-normal);
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-accent-indigo);
    color: var(--color-accent-indigo);
  }

  .btn-outline:hover {
    background: var(--color-accent-indigo);
    color: white;
    transform: translateY(-2px);
  }

  .btn .arrow {
    transition: transform var(--transition-fast);
  }

  .btn:hover .arrow {
    transform: translateX(4px);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive Design */
  @media (max-width: 968px) {
    .downloads-grid {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-emoji {
      font-size: 2.5rem;
    }

    .footer-actions {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .downloads-hero {
      padding: calc(var(--space-4xl) + 60px) 0 var(--space-3xl);
    }

    .hero-stats {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .stat-divider {
      width: 100%;
      height: 1px;
    }

    .downloads-section {
      padding: var(--space-3xl) var(--space-md);
    }

    .downloads-grid {
      gap: var(--space-lg);
      margin-bottom: var(--space-2xl);
    }

    .download-card {
      padding: var(--space-lg);
    }

    .downloads-footer {
      padding: var(--space-xl);
    }
  }

  @media (max-width: 480px) {
    .downloads-grid {
      grid-template-columns: 1fr;
    }

    .file-icon {
      font-size: 2rem;
    }

    .download-title {
      font-size: 1.125rem;
    }
  }
</style>

