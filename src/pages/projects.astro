---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Project data
const projects = [
  {
    title: 'Point of Sale (POS) System',
    description: 'Comprehensive retail solution enabling efficient transaction processing, real-time inventory tracking, and sales reporting. Features include automated stock alerts, customer loyalty programs, advanced analytics dashboards, and employee performance tracking with modular architecture for future integrations.',
    technologies: ['Python', 'PostgreSQL', 'Flask', 'JavaScript', 'React'],
    link: '/projects/pos-system'
  },
  {
    title: 'Livestock Management System',
    description: 'End-to-end ERP-integrated platform centralizing animal farming operations including individual animal records, health monitoring, breeding cycles, feed scheduling, and financial tracking. Features automated alerts, role-based dashboards, and comprehensive reporting for enhanced farm efficiency.',
    technologies: ['Frappe Framework', 'ERPNext', 'Python', 'MariaDB', 'JavaScript'],
    link: '/projects/livestock-management'
  },
  {
    title: 'Hospital Management System',
    description: 'Comprehensive healthcare solution using ERPNext and custom Frappe components unifying patient care workflows, financial processes, pharmacy inventory, and laboratory operations. Features electronic medical records (EMRs), appointment scheduling, billing automation, and real-time resource management.',
    technologies: ['Frappe Framework', 'ERPNext', 'Python', 'MariaDB', 'PostgreSQL'],
    link: '/projects/hospital-management'
  },
  {
    title: 'Dating Mobile App',
    description: 'Modern cross-platform dating application with user profiles, swipe-based matching logic, real-time chat, and push notifications. Built with secure backend architecture, privacy-aware features, and optimized performance delivering 60fps responsiveness on Android and iOS.',
    technologies: ['Flutter', 'FastAPI', 'PostgreSQL', 'Python', 'Dart'],
    link: '/projects/dating-mobile-app'
  },
  {
    title: 'Rent Management Mobile App',
    description: 'Comprehensive platform streamlining landlord-tenant interactions with property listings, automated rent tracking and payments, maintenance request workflows, and role-based dashboards. Features cross-platform consistency with Flutter and robust PostgreSQL backend.',
    technologies: ['Flutter', 'PostgreSQL', 'Python', 'FastAPI', 'Dart'],
    link: '/projects/rent-management'
  },
  {
    title: 'AI Virtual Assistant',
    description: 'Voice-enabled AI assistant for university websites using NLP for structured responses. Features conversational agent capabilities, Google Text-to-Speech integration, and PostgreSQL-backed knowledge base for intelligent query handling and automation.',
    technologies: ['Python', 'Rasa NLP', 'Google TTS', 'PostgreSQL', 'SpaCy'],
    link: '/projects/ai-virtual-assistant'
  },
  {
    title: 'AI Document Intelligence Platform',
    description: 'Designed a document processing pipeline that converts unstructured business documents (invoices, receipts, contracts, and forms) into structured, queryable records. The system performs OCR extraction, semantic classification, and contextual validation using rule engines and language models. Background workers process uploads asynchronously while a review interface allows human verification when confidence scores fall below thresholds. The platform significantly reduces manual data entry and enables automated reporting, auditing, and compliance workflows.',
    technologies: ['Python', 'FastAPI', 'PostgreSQL', 'Redis', 'Celery', 'OCR', 'LLM', 'Vector Search'],
    link: '/projects/ai-document-intelligence'
  },
  {
    title: 'Real-Time Analytics & Monitoring Dashboard',
    description: 'Built a streaming analytics platform that collects application and user activity events, processes them in real time, and visualises operational metrics through interactive dashboards. The system aggregates logs, calculates performance indicators, and triggers alerts when anomalies occur. Designed to help administrators understand system health, usage behaviour, and bottlenecks without relying on delayed batch reports.',
    technologies: ['Python', 'WebSockets', 'Redis Streams', 'TimescaleDB', 'Docker', 'Charting'],
    link: '/projects/realtime-analytics-dashboard'
  },
  {
    title: 'Multi-Tenant SaaS Boilerplate',
    description: 'Developed a reusable production-grade SaaS foundation supporting tenant isolation, authentication, permissions, and subscription lifecycle management. Includes role-based access control, background jobs, rate limiting, and modular service architecture to accelerate building startups or enterprise tools. The template focuses on maintainability and predictable scaling rather than rapid prototyping shortcuts.',
    technologies: ['FastAPI', 'PostgreSQL', 'Redis', 'Celery', 'JWT', 'Docker'],
    link: '/projects/multi-tenant-saas'
  },
  {
    title: 'Knowledge Retrieval AI (RAG) System',
    description: 'Implemented a retrieval-augmented knowledge engine capable of answering domain-specific questions using private organisational data. The system embeds documents into vector space, retrieves relevant context, and guides model responses to minimise hallucinations. Designed for internal documentation, policy assistance, and operational knowledge discovery.',
    technologies: ['Python', 'Embeddings', 'Vector Database', 'LLM', 'API'],
    link: '/projects/rag-knowledge-system'
  },
  {
    title: 'Smart Inventory Forecasting Engine',
    description: 'Created a forecasting service that predicts future stock demand based on historical transactions, seasonality, and trend patterns. The model generates reorder recommendations and integrates into business workflows to prevent shortages and overstocking. Emphasis placed on interpretability and stability over purely academic accuracy.',
    technologies: ['Python', 'Pandas', 'Scikit-learn', 'Time Series', 'FastAPI'],
    link: '/projects/smart-inventory-forecasting'
  },
  {
    title: 'Iris Species Classification using Machine Learning',
    description: 'Built a complete supervised learning classification pipeline predicting iris flower species from morphological measurements. Demonstrates end-to-end ML workflow including exploratory data analysis, visualization, logistic regression training, and comprehensive evaluation achieving 95%+ accuracy on multi-class species prediction.',
    technologies: ['Python', 'Scikit-learn', 'Pandas', 'NumPy', 'Matplotlib', 'Seaborn'],
    link: '/projects/iris-classification-ml'
  },
  {
    title: 'Offline-First Synchronisation Engine',
    description: 'Engineered a data synchronisation mechanism allowing applications to operate without continuous internet connectivity. Local changes are stored, versioned, and reconciled when connectivity returns, resolving conflicts deterministically. Designed for field operations and rural deployments where reliable connectivity cannot be assumed.',
    technologies: ['Python', 'SQLite', 'Diff Sync', 'Background Workers', 'API'],
    link: '/projects/offline-sync-engine'
  },
  {
    title: 'Automated Data Pipeline Framework',
    description: 'Built a modular ETL framework that ingests external datasets, validates records, transforms schemas, and loads them into structured storage. Includes scheduling, retry handling, and monitoring to maintain data reliability across multiple integrations.',
    technologies: ['Python', 'Celery', 'PostgreSQL', 'Redis', 'Data Validation'],
    link: '/projects/data-pipeline-framework'
  },
  {
    title: 'API Gateway & Rate-Limiting Service',
    description: 'Developed a centralised gateway handling authentication, request routing, throttling, and logging for distributed services. Provides unified security policies and protects internal systems from abusive traffic patterns.',
    technologies: ['FastAPI', 'Reverse Proxy', 'Redis', 'JWT', 'Logging'],
    link: '/projects/api-gateway'
  },
  {
    title: 'Intelligent Notification & Messaging Engine',
    description: 'Designed an event-driven communication system that delivers alerts via SMS, email, and in-app notifications based on business triggers. Includes retry logic, scheduling, and user preference management.',
    technologies: ['Python', 'Message Queue', 'Background Workers', 'API'],
    link: '/projects/notification-messaging-engine'
  },
  {
    title: 'AI Assisted Code Knowledge Tool',
    description: 'Created an internal development assistant capable of analysing codebases and answering questions about architecture, dependencies, and behaviour. Helps developers onboard faster and understand legacy systems.',
    technologies: ['Python', 'LLM', 'Embeddings', 'Static Analysis'],
    link: '/projects/ai-code-knowledge-tool'
  },
  {
    title: 'Distributed Job Processing Framework',
    description: 'Implemented a scalable worker system for long-running operations such as report generation, exports, and bulk processing. Supports retries, monitoring, prioritisation, and failure recovery.',
    technologies: ['Celery', 'Redis', 'Python', 'Monitoring'],
    link: '/projects/distributed-job-processing'
  },
  {
    title: 'Secure File Storage & Access Service',
    description: 'Designed a storage service with signed URLs, access policies, and audit logging to safely manage sensitive documents across applications and users.',
    technologies: ['Python', 'Object Storage', 'Authentication', 'Encryption'],
    link: '/projects/secure-file-storage'
  },
  {
    title: 'Data Quality & Validation Engine',
    description: 'Built a validation layer enforcing schema rules, referential integrity checks, and anomaly detection before data enters operational databases. Prevents silent corruption and improves analytics reliability.',
    technologies: ['Python', 'Rules Engine', 'PostgreSQL', 'Data Processing'],
    link: '/projects/data-quality-engine'
  },
  {
    title: 'Workflow Automation Builder',
    description: 'Developed a configurable automation engine where non-technical users can define triggers and actions (if-this-then-that style) to automate operational processes such as approvals, notifications, and record updates.',
    technologies: ['Python', 'Event System', 'Background Jobs', 'UI Integration'],
    link: '/projects/workflow-automation-builder'
  },
];

const projectTags = [
  'All',
  ...Array.from(new Set(projects.flatMap((project) => project.technologies))).sort(),
];
---

<MainLayout
  title="Projects | Victor Muthomi"
  description="Explore my portfolio of enterprise-grade software engineering projects including ERP systems, healthcare solutions, mobile apps, and AI-powered applications."
>
  <!-- Navigation -->
  <Navbar slot="nav" developerName="Victor Muthomi" currentPath="/projects" />

  <!-- Projects Header -->
  <section class="projects-hero">
    <div class="container">
      <div class="hero-content">
        <h1>
          <span class="title-emoji">🚀</span> All <span class="gradient-text-accent">Projects</span>
        </h1>
        <p class="hero-description">
          A comprehensive portfolio of enterprise-grade software solutions across diverse industries, 
          showcasing expertise in full-stack development, ERP systems, mobile applications, and AI/ML integration.
        </p>
        <div class="hero-stats" data-animate="stagger" data-stagger-delay="100">
          <div class="stat-item">
            <span class="stat-emoji">💼</span>
            <span class="stat-value gradient-text">{projects.length}</span>
            <span class="stat-label">Projects Delivered</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-emoji">⚡</span>
            <span class="stat-value gradient-text">100+</span>
            <span class="stat-label">Technologies</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-emoji">🎯</span>
            <span class="stat-value gradient-text">4+ Years</span>
            <span class="stat-label">Experience</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Search + Filter Toolbar -->
  <section class="search-section">
    <div class="container">
      <div class="toolbar">
        <div class="search-wrapper">
          <span class="search-icon">🔍</span>
          <input
            id="project-search"
            type="search"
            placeholder="Search projects..."
            class="search-input glass"
            autocomplete="off"
            spellcheck="false"
          />
          <button id="clear-project-search" class="clear-btn" aria-label="Clear search" hidden>
            ✕
          </button>
        </div>

        <div class="filter-chips" id="project-filter-chips" role="group" aria-label="Filter by technology">
          {projectTags.map((tag) => (
            <button
              class={`chip${tag === 'All' ? ' active' : ''}`}
              data-tag={tag}
              type="button"
            >
              {tag === 'All' ? '✨ All' : tag}
            </button>
          ))}
        </div>
      </div>

      <p id="project-results-count" class="results-count" aria-live="polite"></p>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="projects-section">
    <div class="container">
      <div class="projects-grid" id="projects-grid" data-animate="stagger" data-stagger-delay="100">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            technologies={project.technologies}
            link={project.link}
          />
        ))}
      </div>
      <p id="project-no-results" class="no-results">
        😕 No projects match your search. Try different keywords or clear the filter.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content glass">
        <span class="cta-emoji">🤝</span>
        <h2>Interested in Working Together?</h2>
        <p>Let's discuss how I can help bring your next project to life.</p>
        <div class="cta-actions">
          <a href="mailto:mail@victorblog.me" class="btn btn-primary btn-lg">
            <span>📧</span> Send an Email
          </a>
          <a href="https://wa.me/message/LZH5LE3VNHIVC1" class="btn btn-secondary btn-lg" target="_blank" rel="noopener noreferrer">
            <span>💬</span> WhatsApp Me
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Projects Hero */
  .projects-hero {
    padding: calc(var(--space-5xl) + 80px) 0 var(--space-4xl);
    background: 
      radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(6, 182, 212, 0.1) 0%, transparent 50%);
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-content h1 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: var(--font-weight-black);
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .title-emoji {
    font-size: 0.8em;
  }

  .hero-description {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-3xl);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .stat-emoji {
    font-size: 1.5rem;
    margin-bottom: var(--space-xs);
  }

  .stat-value {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-black);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: var(--font-weight-medium);
  }

  .stat-divider {
    width: 1px;
    height: 80px;
    background: var(--color-border);
  }

  /* Projects Section */
  .projects-section {
    padding: var(--space-4xl) 0;
  }

  /* Search & Filter Toolbar */
  .search-section {
    padding: var(--space-md) 0 var(--space-2xl);
  }

  .toolbar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 1100px;
    margin: 0 auto;
  }

  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    font-size: 1rem;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .search-input {
    width: 100%;
    padding: 0.8rem var(--space-3xl) 0.8rem 2.8rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--color-text-primary);
    font-size: 1rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-input:focus {
    border-color: var(--color-accent-cyan);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }

  .search-input::-webkit-search-cancel-button {
    display: none;
  }

  .clear-btn {
    position: absolute;
    right: var(--space-md);
    background: none;
    border: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.25rem;
    border-radius: var(--radius-full);
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .clear-btn:hover {
    color: var(--color-text-primary);
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .chip {
    padding: 0.35rem 0.9rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-family: var(--font-sans);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast),
      color var(--transition-fast);
    white-space: nowrap;
  }

  .chip:hover {
    border-color: var(--color-accent-cyan);
    color: var(--color-text-primary);
  }

  .chip.active {
    background: rgba(6, 182, 212, 0.18);
    border-color: var(--color-accent-cyan);
    color: var(--color-accent-cyan);
  }

  .results-count {
    max-width: 1100px;
    margin: var(--space-md) auto 0;
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    min-height: 1.2em;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(350px, 100%), 1fr));
    gap: var(--space-xl);
  }

  .project-card[hidden] {
    display: none;
  }

  .no-results {
    max-width: 860px;
    margin: var(--space-3xl) auto 0;
    padding: var(--space-3xl) var(--space-xl);
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1rem;
    display: none;
  }

  .no-results.visible {
    display: block;
  }

  /* CTA Section */
  .cta-section {
    padding: var(--space-4xl) 0 var(--space-5xl);
  }

  .cta-content {
    padding: var(--space-4xl) var(--space-2xl);
    text-align: center;
    border-radius: var(--radius-2xl);
  }

  .cta-emoji {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .cta-content h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-md);
  }

  .cta-content p {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .cta-actions .btn span {
    margin-right: var(--space-xs);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .projects-hero {
      padding: calc(var(--space-4xl) + 60px) 0 var(--space-3xl);
    }

    .toolbar {
      gap: var(--space-md);
    }

    .hero-stats {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .stat-divider {
      width: 100%;
      height: 1px;
    }

    .projects-section {
      padding: var(--space-3xl) 0;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .cta-content {
      padding: var(--space-2xl) var(--space-lg);
    }

    .cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .cta-actions .btn {
      width: 100%;
    }
  }
</style>

<script>
  const searchInput = document.getElementById('project-search') as HTMLInputElement;
  const clearBtn = document.getElementById('clear-project-search') as HTMLButtonElement;
  const chipGroup = document.getElementById('project-filter-chips') as HTMLElement;
  const countEl = document.getElementById('project-results-count') as HTMLElement;
  const noResults = document.getElementById('project-no-results') as HTMLElement | null;

  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('#projects-grid .project-card')
  );

  let activeTag = 'All';
  let query = '';

  function filterProjects() {
    let visible = 0;

    for (const card of cards) {
      const searchText = card.dataset.search ?? '';
      const matchesQuery = !query || searchText.includes(query);

      let matchesTag = true;
      if (activeTag !== 'All') {
        try {
          const tags = JSON.parse(card.dataset.tags ?? '[]') as string[];
          matchesTag = tags.includes(activeTag.toLowerCase());
        } catch {
          matchesTag = false;
        }
      }

      const show = matchesQuery && matchesTag;
      card.hidden = !show;
      if (show) visible++;
    }

    const total = cards.length;
    countEl.textContent =
      visible === total ? '' : `Showing ${visible} of ${total} project${total !== 1 ? 's' : ''}`;

    if (noResults) noResults.classList.toggle('visible', visible === 0);
  }

  searchInput?.addEventListener('input', () => {
    query = searchInput.value.trim().toLowerCase();
    clearBtn.hidden = query === '';
    filterProjects();
  });

  clearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    query = '';
    clearBtn.hidden = true;
    searchInput.focus();
    filterProjects();
  });

  chipGroup?.addEventListener('click', (event) => {
    const button = (event.target as HTMLElement).closest('.chip') as HTMLButtonElement | null;
    if (!button) return;

    activeTag = button.dataset.tag ?? 'All';
    chipGroup.querySelectorAll('.chip').forEach((chip) => chip.classList.remove('active'));
    button.classList.add('active');
    filterProjects();
  });

  filterProjects();
</script>
