---
import MainLayout from './MainLayout.astro';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  readingTime?: string;
  tags?: string[];
  coverImage?: string;
}

const {
  title,
  description,
  date,
  readingTime = '5 min read',
  tags = [],
  coverImage,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<MainLayout title={`${title} | Blog — Victor Muthomi`} description={description}>
  <!-- Navigation -->
  <Navbar slot="nav" developerName="Victor Muthomi" currentPath="/blog" />

  <!-- Blog Post Hero -->
  <section class="post-hero">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li aria-current="page">{title}</li>
        </ol>
      </nav>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>

      <div class="post-meta">
        <span class="meta-item">
          <span class="meta-icon">📅</span>
          {formattedDate}
        </span>
        <span class="meta-divider">·</span>
        <span class="meta-item">
          <span class="meta-icon">⏱️</span>
          {readingTime}
        </span>
        <span class="meta-divider">·</span>
        <span class="meta-item">
          <span class="meta-icon">✍️</span>
          Victor Muthomi
        </span>
      </div>
    </div>
  </section>

  {coverImage && (
    <div class="cover-image-wrapper">
      <div class="container">
        <img src={coverImage} alt={title} class="cover-image" />
      </div>
    </div>
  )}

  <!-- Blog Content -->
  <article class="blog-article">
    <div class="container">
      <div class="prose">
        <slot />
      </div>

      <!-- Back to Blog -->
      <div class="back-link-wrapper">
        <a href="/blog" class="back-link">
          <span>←</span> Back to Blog
        </a>
      </div>
    </div>
  </article>
</MainLayout>

<style>
  /* ─── Hero ─────────────────────────────────────────────────────────── */
  .post-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    background: radial-gradient(
      ellipse 80% 60% at 50% -10%,
      rgba(99, 102, 241, 0.12) 0%,
      transparent 70%
    );
  }

  /* Breadcrumb */
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    list-style: none;
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-left: var(--space-sm);
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--color-accent-indigo);
  }

  .breadcrumb [aria-current='page'] {
    color: var(--color-text-secondary);
  }

  /* Tags */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(99, 102, 241, 0.15);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: var(--radius-full);
    font-size: 0.78rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-indigo);
    letter-spacing: 0.03em;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: var(--font-weight-bold);
    line-height: 1.15;
    color: var(--color-text-primary);
    margin-bottom: var(--space-lg);
    max-width: 820px;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 700px;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .meta-icon {
    font-size: 1rem;
  }

  .meta-divider {
    color: var(--color-text-muted);
  }

  /* ─── Cover Image ───────────────────────────────────────────────────── */
  .cover-image-wrapper {
    padding: 0 0 var(--space-2xl);
  }

  .cover-image {
    width: 100%;
    max-height: 440px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  /* ─── Prose ─────────────────────────────────────────────────────────── */
  .blog-article {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .prose {
    max-width: 780px;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .prose :global(h2) {
    font-size: 1.65rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin: var(--space-3xl) 0 var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(a) {
    color: var(--color-accent-indigo);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .prose :global(a:hover) {
    color: var(--color-accent-cyan);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-lg) var(--space-xl);
  }

  .prose :global(li) {
    margin-bottom: var(--space-sm);
  }

  .prose :global(blockquote) {
    margin: var(--space-xl) 0;
    padding: var(--space-lg) var(--space-xl);
    border-left: 4px solid var(--color-accent-indigo);
    background: rgba(99, 102, 241, 0.06);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.45em;
    color: var(--color-accent-cyan);
  }

  .prose :global(pre) {
    margin: var(--space-xl) 0;
    padding: var(--space-lg);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.9rem;
    color: var(--color-text-primary);
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-3xl) 0;
  }

  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
  }

  /* ─── Back link ─────────────────────────────────────────────────────── */
  .back-link-wrapper {
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    font-size: 0.95rem;
    transition: color var(--transition-fast), gap var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent-indigo);
    gap: var(--space-md);
  }

  /* ─── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .post-hero {
      padding: var(--space-3xl) 0 var(--space-xl);
    }

    .prose {
      font-size: 1rem;
    }
  }
</style>
